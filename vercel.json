{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/sitemap.xml", "dest": "/api/sitemap" },
    { "src": "/free-wallpapers", "dest": "/api/seo-free" },
    { "src": "/", "dest": "/api/seo-home" },
    { "src": "/homepage", "dest": "/api/seo-home" },
    { "src": "/premium", "dest": "/api/seo-premium" },
    { "src": "/upgrade", "dest": "/api/seo-premium" },
    { "src": "/collections", "dest": "/api/seo-collections" },
    { "src": "/categories", "dest": "/api/seo-categories" },
    { "src": "/mobile-wallpapers", "dest": "/api/seo-mobile" },
    { "src": "/ai-wallpapers", "dest": "/api/seo-ai" },
    { "src": "/wallpaper/(?<slug>[^/]+)", "dest": "/api/seo-wallpaper?slug=$slug" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
