{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {}
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/wallpaper/([^/]+)", "dest": "/api/seo/wallpaper/$1" },
    { "src": "/category/([^/]+)", "dest": "/api/seo/category/$1" },
    { "src": "/collection/([^/]+)", "dest": "/api/seo/collection/$1" },
    { "src": "/(.*)", "dest": "/" }
  ]
}
