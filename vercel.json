{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/sitemaps/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/sitemaps/static.xml", "destination": "/api/sitemaps?kind=static" },
    { "source": "/sitemaps/:kind-:page.xml", "destination": "/api/sitemaps?kind=:kind&page=:page" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
