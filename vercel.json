{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/sitemap-static.xml", "destination": "/api/sitemap-page?type=static" },
    { "source": "/sitemap-wallpapers-:page.xml", "destination": "/api/sitemap-page?type=wallpapers&page=:page" },
    { "source": "/sitemap-ringtones.xml", "destination": "/api/sitemap-page?type=ringtones" },
    { "source": "/sitemap-live.xml", "destination": "/api/sitemap-page?type=live" },
    { "source": "/free-wallpapers", "destination": "/api/seo?route=static&page=free-wallpapers" },
    { "source": "/premium", "destination": "/api/seo?route=static&page=premium" },
    { "source": "/upgrade", "destination": "/api/seo?route=static&page=upgrade" },
    { "source": "/collections", "destination": "/api/seo?route=static&page=collections" },
    { "source": "/categories", "destination": "/api/seo?route=static&page=categories" },
    { "source": "/mobile-wallpapers", "destination": "/api/seo?route=static&page=mobile-wallpapers" },
    { "source": "/ai-wallpapers", "destination": "/api/seo?route=static&page=ai-wallpapers" },
    { "source": "/ringtones", "destination": "/api/seo?route=static&page=ringtones" },
    { "source": "/category/:slug", "destination": "/api/seo?route=category&slug=:slug" },
    { "source": "/wallpaper/:slug", "destination": "/api/seo?route=wallpaper&slug=:slug" },
    { "source": "/ringtone/:slug", "destination": "/api/seo?route=ringtone&slug=:slug" },
    { "source": "/ringtones/category/:slug", "destination": "/api/seo?route=ringtone-category&slug=:slug" },
    { "source": "/live-wallpapers", "destination": "/api/seo?route=live" },
    { "source": "/live-wallpaper/:slug", "destination": "/api/seo?route=live&slug=:slug" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
