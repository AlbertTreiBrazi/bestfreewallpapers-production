{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/sitemaps/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "routes": [
    { "src": "^/sitemap\\.xml$", "dest": "/api/sitemap" },
    { "src": "^/sitemaps/static\\.xml$", "dest": "/api/sitemaps?kind=static" },
    { "src": "^/sitemaps/(wallpapers|categories|collections)-([0-9]+)\\.xml$", "dest": "/api/sitemaps?kind=$1&page=$2" },
    { "src": "/(.*)", "dest": "/" }
  ]
}
